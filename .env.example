# ============================================================
# Gravador — environment variables
# Copy to .env and fill values. Never commit .env.
# ============================================================

# --- Supabase (cloud or local via `supabase start`) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Public keys (exposed to client)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
NEXT_PUBLIC_APP_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
EXPO_PUBLIC_API_URL=http://localhost:3000

# --- AI providers (BYOK) ---
# Set at least one. In SaaS mode, platform keys are used as fallback.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Self-host: local models via Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Default providers (override per workspace in DB)
AI_TRANSCRIBE_PROVIDER=groq           # groq | openai | local
AI_CHAT_PROVIDER=anthropic            # anthropic | openai | google | ollama
AI_CHAT_MODEL=claude-sonnet-4-6
AI_EMBEDDING_PROVIDER=openai          # openai | ollama
AI_EMBEDDING_MODEL=text-embedding-3-small

# --- Job orchestration (Trigger.dev) ---
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev

# --- OAuth integrations (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# --- Billing (cloud SaaS only) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# --- Deployment mode ---
# Controls feature gating. `cloud` = SaaS; `selfhost` = Docker.
DEPLOYMENT_MODE=cloud

# --- Observability (optional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
SENTRY_DSN=
