# ============================================================
# Gravador - environment variables
# Copy to .env and fill values. Never commit .env.
# ============================================================

# --- Firebase ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=hocapp-44760.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=hocapp-44760
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=hocapp-44760.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# Firebase Admin (server-side) - JSON string of service account key
FIREBASE_SERVICE_ACCOUNT_KEY=

# Mobile app (Expo)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=hocapp-44760.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=hocapp-44760
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=hocapp-44760.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_API_URL=http://localhost:3000

# --- AI providers (BYOK) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Internal webhook ---
INTERNAL_WEBHOOK_SECRET=

# --- Billing (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Deployment mode ---
DEPLOYMENT_MODE=cloud

# --- Web feature flags (rollout controls) ---
NEXT_PUBLIC_FF_WORKSPACE_DOWNLOADS=true
NEXT_PUBLIC_FF_RECORDING_LIFECYCLE_V1=false
NEXT_PUBLIC_FF_AUDIO_EDITING_V1=false
NEXT_PUBLIC_FF_NOTIFICATIONS_V1=false
NEXT_PUBLIC_FF_BULK_OPS_V1=false
