# Required: Firebase client config (baked into JS bundles at build time)
# Get these from Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=hocapp-44760.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=hocapp-44760
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=hocapp-44760.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=anotes

# Required: Firebase Admin SDK service account key (JSON string, server-side only)
# Get from Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the entire JSON content as a single line
FIREBASE_SERVICE_ACCOUNT_KEY=

# Optional: Explicit Firebase Admin runtime settings for Cloud Run / self-hosting
FIREBASE_PROJECT_ID=hocapp-44760
FIREBASE_STORAGE_BUCKET=hocapp-44760.firebasestorage.app
FIRESTORE_DATABASE_ID=anotes

# Optional: App URL for share links
NEXT_PUBLIC_APP_URL=https://anotes.web.app

# Optional: AI provider keys (server-side, for transcription/summarization)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: Webhook secret for recording upload notifications
INTERNAL_WEBHOOK_SECRET=

# Optional: Admin emails (comma-separated) — only these users see the Dashboard
NEXT_PUBLIC_ADMIN_EMAILS=

# Optional: Firebase emulators (development only)
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
