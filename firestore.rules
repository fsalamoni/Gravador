rules_version = '2';

service cloud.firestore {
  match /databases/anotes/documents {

    // ── Helper functions ──
    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isWorkspaceMember(wsId) {
      return isAuth() &&
        exists(/databases/anotes/documents/workspaces/$(wsId)/members/$(uid()));
    }

    function isWorkspaceAdmin(wsId) {
      return isAuth() &&
        get(/databases/anotes/documents/workspaces/$(wsId)/members/$(uid())).data.role in ['owner', 'admin'];
    }

    function isWorkspaceOwner(wsId) {
      return isAuth() &&
        get(/databases/anotes/documents/workspaces/$(wsId)/members/$(uid())).data.role == 'owner';
    }

    // ── Users ──
    match /users/{userId} {
      allow read: if isAuth() && uid() == userId;
      allow create: if isAuth() && uid() == userId;
      allow update: if isAuth() && uid() == userId;
      allow delete: if false;
    }

    // ── Workspaces ──
    match /workspaces/{wsId} {
      allow read: if isWorkspaceMember(wsId);
      allow create: if isAuth();
      allow update: if isWorkspaceAdmin(wsId);
      allow delete: if isWorkspaceOwner(wsId);

      match /members/{memberId} {
        allow read: if isWorkspaceMember(wsId);
        allow write: if isWorkspaceAdmin(wsId);
      }

      match /folders/{folderId} {
        allow read: if isWorkspaceMember(wsId);
        allow write: if isWorkspaceMember(wsId);
      }

      match /tags/{tagId} {
        allow read: if isWorkspaceMember(wsId);
        allow write: if isWorkspaceMember(wsId);
      }
    }

    // ── Recordings ──
    match /recordings/{recId} {
      allow read: if isAuth() && isWorkspaceMember(resource.data.workspaceId);
      allow create: if isAuth() && isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isAuth() && isWorkspaceMember(resource.data.workspaceId);
      allow delete: if isAuth() && isWorkspaceAdmin(resource.data.workspaceId);

      match /transcript_segments/{segId} {
        allow read: if isAuth();
        allow write: if false; // server-only via admin SDK
      }

      match /ai_outputs/{kind} {
        allow read: if isAuth();
        allow write: if false; // server-only via admin SDK
      }

      match /embeddings/{chunkId} {
        allow read: if isAuth();
        allow write: if false; // server-only via admin SDK
      }

      match /action_items/{itemId} {
        allow read: if isAuth();
        allow update: if isAuth(); // toggle done
        allow create, delete: if false; // server-only
      }
    }

    // ── Shares ──
    match /shares/{shareId} {
      allow read: if true; // public shares are readable by token lookup
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.createdBy == uid();
      allow delete: if isAuth() && resource.data.createdBy == uid();
    }

    // ── Jobs ──
    match /jobs/{jobId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false; // server-only
    }
  }
}
