{
  "name": "gravador",
  "private": true,
  "version": "0.1.0",
  "description": "Gravador — open-source AI audio capture + web workspace (Plaud Note Pro alternative). Bilingual PT-BR / EN.",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate --filter=@gravador/db",
    "db:push": "turbo run db:push --filter=@gravador/db",
    "db:studio": "turbo run db:studio --filter=@gravador/db",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "selfhost:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "selfhost:down": "docker compose -f infra/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "2.3.3",
    "typescript": "5.7.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.2",
      "@types/react-dom": "19.0.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      },
      "ignoreMissing": ["react", "react-dom"]
    }
  }
}
