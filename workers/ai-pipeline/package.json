{
  "name": "@gravador/ai-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "pnpm run audio-jobs:loop",
    "audio-jobs:once": "pnpm run build && node dist/tasks/process-audio-edit-jobs.js --once",
    "audio-jobs:loop": "pnpm run build && node dist/tasks/process-audio-edit-jobs.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@gravador/ai": "file:../../packages/ai",
    "@gravador/core": "file:../../packages/core",
    "@gravador/db": "file:../../packages/db",
    "firebase-admin": "^13.0.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@types/node": "22.10.2"
  }
}
